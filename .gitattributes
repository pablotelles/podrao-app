# Normalize line endings on commit. Working tree gets LF (or CRLF on Windows
# if core.autocrlf=true), but the repo always stores LF.
* text=auto eol=lf

# Binary files — never normalize
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

# Shell scripts must always be LF (won't run on Linux/Mac otherwise)
*.sh text eol=lf
.husky/* text eol=lf
